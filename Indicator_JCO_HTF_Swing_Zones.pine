// © jcornier
//
// Version: 1.6
// GitHub: https://github.com/jcornierfra/TradingView_Indicator_JCO_HTF_Swing_Zones
//
// Description: Draws supply/demand zones based on HTF swing highs and lows.
//              Each zone covers the wick area of a pivot candle (between body and wick tip).
//              Features include:
//              - Configurable HTF timeframe and pivot length
//              - N closest swing high zones above current price (ordered by wick proximity)
//              - N closest swing low zones below current price (ordered by wick proximity)
//              - Stateless backward scan on last bar only; zone overlap is intentional
//                (overlapping wicks indicate high-impact price areas)
//              - Mitigation filter: zones closed beyond wick by a more recent HTF candle are skipped
//              - Configurable zone colors, border, and midline
//
// Changelog:
//   v1.6 - 2026-03-26
//     - Fusion parameter: 3-option selector (Aucune / Totale / Exclusive).
//       Exclusive: merged zone spans from highest wick tip to the wick tip just
//       below (highs) or just above (lows). Default: Exclusive.
//     - Cascade merge: after a primary merge, the result is checked against all
//       previously found zones until no more overlap exists (while loop).
//   v1.5 - 2026-03-23
//     - Zone fusion: overlapping zones are merged into one (max extent, oldest timestamp).
//       The zone counter decrements only once per merged group.
//       HTF history buffer increased to 2000 bars (~2.7 years of H4 data).
//   v1.4 - 2026-03-23
//     - All calculations now use HTF bar space (one sample per closed HTF bar).
//       Eliminates timeframe-dependent behaviour (e.g. zones missing on 15-minute charts).
//       The chart timeframe is only used to anchor the start of drawn rectangles.
//   v1.3 - 2026-03-23
//     - Added mitigation filter: a zone is skipped if any more recent HTF candle
//       has closed beyond the wick (close > wick for highs, close < wick for lows)
//   v1.2 - 2026-03-21
//     - Removed unused merge/fusion parameter and functions (dead code cleanup)
//   v1.1 - 2026-03-20
//     - Fixed zone positioning: xloc.bar_time to anchor boxes correctly across session gaps
//     - Fixed zone selection: wick-to-wick ladder (z_top > last_h_top) replaces
//       body-to-wick, so spike candles with small bodies are no longer skipped
//   v1.0 - 2026-03-20
//     - Initial release

//@version=6
indicator("JCO HTF Swing Zones", overlay=true, max_boxes_count=500, max_lines_count=500)

// ══════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════
grpC = "Configuration"
i_tf    = input.timeframe("240",  "Timeframe HTF",                         group=grpC)
i_nb_h  = input.int(3,   "Nb zones High",      minval=1,  maxval=10,       group=grpC)
i_nb_l  = input.int(3,   "Nb zones Low",       minval=1,  maxval=10,       group=grpC)
i_plen  = input.int(5,   "Longueur pivot",     minval=2,  maxval=20,       group=grpC)
i_fmode = input.string("Exclusive", "Fusion",
          options=["Aucune", "Totale", "Exclusive"],                         group=grpC)

grpA = "Apparence"
i_zcol  = input.color(color.new(color.gray, 85),  "Couleur zone",          group=grpA)
i_bcol  = input.color(color.new(color.gray, 70),  "Bordure",               group=grpA)
i_smid  = input.bool(true,  "Afficher le milieu",                           group=grpA)
i_mcol  = input.color(color.gray,                 "Couleur milieu",         group=grpA)
i_mw    = input.int(1,  "Epaisseur milieu", minval=1, maxval=4,             group=grpA)

// ══════════════════════════════════════════════════════════════
// HTF DATA
// Toutes les series sont échantillonnées avec [1] au moment où
// ta.change(htf_bar_time) détecte une nouvelle bougie HTF :
// à cet instant, [1] pointe vers la dernière barre de la bougie
// HTF qui vient de se clôturer, ce qui donne des valeurs finalisées.
// ══════════════════════════════════════════════════════════════
htf_bar_time = request.security(syminfo.tickerid, i_tf,
                   time,                                                    lookahead=barmerge.lookahead_off)
htf_ph       = request.security(syminfo.tickerid, i_tf,
                   ta.pivothigh(i_plen, i_plen),                            lookahead=barmerge.lookahead_off)
htf_pl       = request.security(syminfo.tickerid, i_tf,
                   ta.pivotlow (i_plen, i_plen),                            lookahead=barmerge.lookahead_off)
htf_phb      = request.security(syminfo.tickerid, i_tf,
                   not na(ta.pivothigh(i_plen, i_plen)) ?
                     math.max(open[i_plen], close[i_plen]) : float(na),    lookahead=barmerge.lookahead_off)
htf_plb      = request.security(syminfo.tickerid, i_tf,
                   not na(ta.pivotlow(i_plen, i_plen)) ?
                     math.min(open[i_plen], close[i_plen]) : float(na),    lookahead=barmerge.lookahead_off)
htf_ph_time  = request.security(syminfo.tickerid, i_tf,
                   time[i_plen],                                            lookahead=barmerge.lookahead_off)
htf_pl_time  = request.security(syminfo.tickerid, i_tf,
                   time[i_plen],                                            lookahead=barmerge.lookahead_off)
htf_close    = request.security(syminfo.tickerid, i_tf,
                   close,                                                   lookahead=barmerge.lookahead_off)

// ══════════════════════════════════════════════════════════════
// HISTORIQUE HTF  –  une entrée par bougie HTF clôturée
// Limité à MAX_HTF bougies HTF (suffisant pour tout timeframe graphique).
// ══════════════════════════════════════════════════════════════
MAX_HTF = 2000

var array<float> arr_ph      = array.new<float>()
var array<float> arr_phb     = array.new<float>()
var array<float> arr_pl      = array.new<float>()
var array<float> arr_plb     = array.new<float>()
var array<float> arr_close   = array.new<float>()
var array<int>   arr_ph_time = array.new<int>()
var array<int>   arr_pl_time = array.new<int>()

bool new_htf_bar = ta.change(htf_bar_time) != 0
if new_htf_bar
    // [1] : valeurs de la bougie HTF qui vient de se clôturer
    arr_ph.unshift     (htf_ph[1])
    arr_phb.unshift    (htf_phb[1])
    arr_pl.unshift     (htf_pl[1])
    arr_plb.unshift    (htf_plb[1])
    arr_close.unshift  (htf_close[1])
    arr_ph_time.unshift(htf_ph_time[1])
    arr_pl_time.unshift(htf_pl_time[1])
    if arr_ph.size() > MAX_HTF
        arr_ph.pop()
        arr_phb.pop()
        arr_pl.pop()
        arr_plb.pop()
        arr_close.pop()
        arr_ph_time.pop()
        arr_pl_time.pop()

// ══════════════════════════════════════════════════════════════
// ARRAYS (zones dessinées)
// ══════════════════════════════════════════════════════════════
var array<float> ht = array.new<float>()
var array<float> hb = array.new<float>()
var array<int>   hi = array.new<int>()
var array<box>   hx = array.new<box>()
var array<line>  hm = array.new<line>()

var array<float> lt = array.new<float>()
var array<float> lb = array.new<float>()
var array<int>   li = array.new<int>()
var array<box>   lx = array.new<box>()
var array<line>  lm = array.new<line>()

// ══════════════════════════════════════════════════════════════
// HELPERS
// bar_l : timestamp de la bougie pivot, utilisé avec xloc.bar_time
// ══════════════════════════════════════════════════════════════
f_midline(int bar_l, float top, float bot) =>
    float mid = (top + bot) / 2.0
    line.new(bar_l, mid, bar_l + 1, mid,
        color  = i_smid ? i_mcol : color.new(color.white, 100),
        width  = i_mw,
        extend = extend.right,
        xloc   = xloc.bar_time)

f_add_h(float top, float bot, int bar_l) =>
    box b = box.new(bar_l, top, bar_l + 1, bot,
        bgcolor      = i_zcol,
        border_color = i_bcol,
        extend       = extend.right,
        xloc         = xloc.bar_time)
    line m = f_midline(bar_l, top, bot)
    ht.push(top)
    hb.push(bot)
    hi.push(bar_l)
    hx.push(b)
    hm.push(m)

f_add_l(float top, float bot, int bar_l) =>
    box b = box.new(bar_l, top, bar_l + 1, bot,
        bgcolor      = i_zcol,
        border_color = i_bcol,
        extend       = extend.right,
        xloc         = xloc.bar_time)
    line m = f_midline(bar_l, top, bot)
    lt.push(top)
    lb.push(bot)
    li.push(bar_l)
    lx.push(b)
    lm.push(m)

f_del_h(int idx) =>
    box.delete(hx.get(idx))
    line.delete(hm.get(idx))
    ht.remove(idx)
    hb.remove(idx)
    hi.remove(idx)
    hx.remove(idx)
    hm.remove(idx)

f_del_l(int idx) =>
    box.delete(lx.get(idx))
    line.delete(lm.get(idx))
    lt.remove(idx)
    lb.remove(idx)
    li.remove(idx)
    lx.remove(idx)
    lm.remove(idx)

// ══════════════════════════════════════════════════════════════
// SCAN  –  exécuté sur la dernière barre uniquement
// Itère sur l'historique HTF (une entrée par bougie HTF clôturée).
// Règle ladder : wick-to-wick (z_top > last_h_top / z_bot < last_l_bot).
// Mitigation : zone ignorée si une bougie HTF plus récente a clôturé
//              au-delà de la mèche (seules les bougies clôturées comptent).
// ══════════════════════════════════════════════════════════════
if barstate.islast

    while ht.size() > 0
        f_del_h(0)
    while lt.size() > 0
        f_del_l(0)

    int   found_h    = 0
    int   found_l    = 0
    int   n          = arr_ph.size()
    float last_h_top = close
    float last_l_bot = close

    // k = -1 : bougie HTF en cours (valeurs live, pas encore dans les tableaux)
    // k >= 0 : bougies HTF clôturées (tableaux)
    for k = -1 to n - 1
        if found_h >= i_nb_h and found_l >= i_nb_l
            break

        bool  cur      = k < 0
        float ph_val   = cur ? htf_ph        : arr_ph.get(k)
        float phb_val  = cur ? htf_phb       : arr_phb.get(k)
        float pl_val   = cur ? htf_pl        : arr_pl.get(k)
        float plb_val  = cur ? htf_plb       : arr_plb.get(k)
        int   ph_t     = cur ? htf_ph_time   : arr_ph_time.get(k)
        int   pl_t     = cur ? htf_pl_time   : arr_pl_time.get(k)
        int   mit_end  = math.max(k, 0) - 1  // borne sup de la boucle de mitigation

        // Pivot haut : accepté si son WICK est au-dessus du wick précédent
        if found_h < i_nb_h and not na(ph_val)
            float z_top = ph_val
            float z_bot = phb_val
            if not na(z_bot) and z_top > z_bot and z_top > last_h_top
                bool mitigated = false
                for m = 0 to mit_end
                    if arr_close.get(m) > z_top
                        mitigated := true
                        break
                if not mitigated
                    if ht.size() > 0
                        float pt = ht.get(ht.size() - 1)
                        float pb = hb.get(hb.size() - 1)
                        int   pi = hi.get(hi.size() - 1)
                        if i_fmode != "Aucune" and z_top >= pb and pt >= z_bot
                            // Fusion primaire
                            float fbot = i_fmode == "Exclusive" ? pt : math.min(z_bot, pb)
                            f_del_h(ht.size() - 1)
                            f_add_h(z_top, fbot, math.min(ph_t, pi))
                            // Cascade : la zone fusionnée peut désormais chevaucher la zone précédente
                            while ht.size() >= 2
                                float ct  = ht.get(ht.size() - 1)
                                float cb  = hb.get(hb.size() - 1)
                                int   ci  = hi.get(hi.size() - 1)
                                float pt2 = ht.get(ht.size() - 2)
                                float pb2 = hb.get(hb.size() - 2)
                                int   pi2 = hi.get(hi.size() - 2)
                                if ct >= pb2 and pt2 >= cb
                                    float fbot2 = i_fmode == "Exclusive" ? pt2 : math.min(cb, pb2)
                                    f_del_h(ht.size() - 1)
                                    f_del_h(ht.size() - 1)
                                    f_add_h(ct, fbot2, math.min(ci, pi2))
                                    found_h -= 1
                                else
                                    break
                        else
                            f_add_h(z_top, z_bot, ph_t)
                            found_h += 1
                    else
                        f_add_h(z_top, z_bot, ph_t)
                        found_h += 1
                    last_h_top := z_top

        // Pivot bas : accepté si son WICK est en-dessous du wick précédent
        if found_l < i_nb_l and not na(pl_val)
            float z_top = plb_val
            float z_bot = pl_val
            if not na(z_top) and z_top > z_bot and z_bot < last_l_bot
                bool mitigated = false
                for m = 0 to mit_end
                    if arr_close.get(m) < z_bot
                        mitigated := true
                        break
                if not mitigated
                    if lt.size() > 0
                        float pt = lt.get(lt.size() - 1)
                        float pb = lb.get(lb.size() - 1)
                        int   pi = li.get(li.size() - 1)
                        if i_fmode != "Aucune" and z_top >= pb and pt >= z_bot
                            // Fusion primaire
                            float ftop = i_fmode == "Exclusive" ? pb : math.max(z_top, pt)
                            f_del_l(lt.size() - 1)
                            f_add_l(ftop, z_bot, math.min(pl_t, pi))
                            // Cascade : la zone fusionnée peut désormais chevaucher la zone précédente
                            while lt.size() >= 2
                                float ct  = lt.get(lt.size() - 1)
                                float cb  = lb.get(lb.size() - 1)
                                int   ci  = li.get(li.size() - 1)
                                float pt2 = lt.get(lt.size() - 2)
                                float pb2 = lb.get(lb.size() - 2)
                                int   pi2 = li.get(li.size() - 2)
                                if ct >= pb2 and pt2 >= cb
                                    float ftop2 = i_fmode == "Exclusive" ? pb2 : math.max(ct, pt2)
                                    f_del_l(lt.size() - 1)
                                    f_del_l(lt.size() - 1)
                                    f_add_l(ftop2, cb, math.min(ci, pi2))
                                    found_l -= 1
                                else
                                    break
                        else
                            f_add_l(z_top, z_bot, pl_t)
                            found_l += 1
                    else
                        f_add_l(z_top, z_bot, pl_t)
                        found_l += 1
                    last_l_bot := z_bot
